# Copy to .env.local for local dev; set the same vars in Vercel for prod.

# Gemini (Google AI Studio)
GEMINI_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Admin gate (plain string; used only server-side)
ADMIN_PASSWORD=

# Upstash Redis (Vercel Marketplace integration injects these automatically)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
